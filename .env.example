# Copy this file to .env and fill in your values.
# Hugo reads HUGO_PARAMS_* variables and merges them into .Site.Params.*
# Variables must be exported so Hugo (a subprocess) can read them.

# Firebase project config (not secret — safe to expose to the browser)
export HUGO_PARAMS_FIREBASE_API_KEY=
export HUGO_PARAMS_FIREBASE_AUTH_DOMAIN=
export HUGO_PARAMS_FIREBASE_PROJECT_ID=
export HUGO_PARAMS_FIREBASE_STORAGE_BUCKET=
export HUGO_PARAMS_FIREBASE_MESSAGING_SENDER_ID=
export HUGO_PARAMS_FIREBASE_APP_ID=

# Backend API base URL (collection-market-tracker-backend on Cloud Run)
export HUGO_PARAMS_BACKENDURL=http://localhost:8080

# Comma-separated list of emails allowed to sign in (mirrors backend ALLOWED_EMAILS)
export HUGO_PARAMS_ALLOWED_EMAILS=you@example.com

# Static data sources (GitHub-first, GCS fallback)
# Data repo: https://github.com/FutureGadgetCollections/collection-market-tracker-data
export HUGO_PARAMS_GCS_DATA_BUCKET=collection-market-tracker-data
export HUGO_PARAMS_GITHUB_DATA_REPO=FutureGadgetCollections/collection-market-tracker-data
